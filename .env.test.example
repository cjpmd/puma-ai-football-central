# Edge function test configuration — copy to .env.test (gitignored).
# Tests run against the project these credentials point at.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service role key is used only for test setup/teardown (creating disposable
# test users, resetting rate-limit counters, seeding fixtures).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Domain used for disposable test-user emails (accounts are created and
# deleted via the admin API; nothing is ever mailed to them).
TEST_EMAIL_DOMAIN=example.com

# Real inbox for Tier 2 email happy-path tests (send-invitation-email,
# send-availability-notification). Leave empty to skip those.
TEST_INBOX_EMAIL=

# Tier 2: tests with real side effects (emails, paid AI calls, DB writes).
RUN_SIDE_EFFECT_TESTS=0

# Set to 1 to skip the rate-limit burn tests (each fires 10-31 requests).
SKIP_SLOW_TESTS=0
